{
  "name": "@primebrick/dal-pg",
  "version": "0.2.0",
  "description": "Type-driven PostgreSQL Data Access Layer — metadata-based entity decorators, type-safe Repository, bulk ops with TEMP TABLE strategy. Part of the @primebrick/dal-* family (dal-pg, dal-mssql, dal-mariadb, ...).",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": "24"
  },
  "author": "Michael Sogos",
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelsogos/primebrick-v3-dal"
  },
  "homepage": "https://github.com/michaelsogos/primebrick-v3-dal#readme",
  "bugs": {
    "url": "https://github.com/michaelsogos/primebrick-v3-dal/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors/errors.d.ts",
      "import": "./dist/errors/errors.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "version:auto": "node scripts/version-sync.mjs",
    "prebuild": "node scripts/version-sync.mjs",
    "build": "tsc",
    "prepare": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:benchmark": "vitest run --config test/benchmark.vitest.config.ts",
    "extract-docs": "node scripts/extract-api-docs.mjs"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "packageManager": "pnpm@9.15.9",
  "dependencies": {
    "pg": "8.22.0",
    "pg-query-stream": "4.16.0",
    "reflect-metadata": "0.2.2"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "dotenv": "17.4.2",
    "typedoc": "0.28.20",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
